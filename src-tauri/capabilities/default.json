{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Portal main window — 창 show/hide/position 제어 및 이벤트",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:event:default",
    "opener:default",
    "dialog:allow-open"
  ]
}
